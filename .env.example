# This is an example of your .env file format, which pnpm db:setup will create.
# Note: this must be .env, not .env.local, without further configuration changes.
POSTGRES_URL=postgresql://***
STRIPE_SECRET_KEY=sk_test_***
STRIPE_WEBHOOK_SECRET=whsec_***
BASE_URL=http://localhost:3000
AUTH_SECRET=***

# ============================================
# Site Configuration
# ============================================
# Public site URL (used for metadata, sitemap, etc.)
# Production: https://colourclouds.digital
# Development: http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ============================================
# Google Sheets API Configuration
# ============================================
# Google Service Account email address
# Obtain from Google Cloud Console when creating a service account
# Example: your-service-account@project-id.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com

# Google Service Account private key
# Obtain from Google Cloud Console when creating a service account key (JSON format)
# Copy the "private_key" field from the JSON file
# IMPORTANT: Keep the quotes and newline characters (\n) in the key
# Example: "-----BEGIN PRIVATE KEY-----\nMIIEvQIBADANBg...\n-----END PRIVATE KEY-----\n"
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Google Sheets spreadsheet ID
# Found in the Google Sheets URL: https://docs.google.com/spreadsheets/d/{SPREADSHEET_ID}/edit
# Example: 1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgvE2upms
GOOGLE_SHEET_ID=your-spreadsheet-id-here

# ============================================
# Rate Limiting Configuration
# ============================================
# Time window for rate limiting in milliseconds
# Default: 60000 (1 minute)
RATE_LIMIT_WINDOW=60000

# Maximum number of requests allowed per time window
# Default: 5 requests per minute for form submissions
RATE_LIMIT_MAX_REQUESTS=5

# ============================================
# Email Configuration (Nodemailer)
# ============================================
# SMTP server host (e.g., smtp.gmail.com for Gmail)
SMTP_HOST=smtp.gmail.com

# SMTP server port (587 for TLS, 465 for SSL)
SMTP_PORT=587

# Use secure connection (true for port 465, false for port 587)
SMTP_SECURE=false

# SMTP authentication username (your email address)
SMTP_USER=t16854308@gmail.com

# SMTP authentication password (use App Password for Gmail)
# For Gmail: https://myaccount.google.com/apppasswords
SMTP_PASSWORD=InanOffice2026

# Admin email address (receives contact form and newsletter notifications)
ADMIN_EMAIL=colourclouds042@gmail.com

# ============================================
# Google reCAPTCHA v3 Configuration
# ============================================
# Get your keys from: https://www.google.com/recaptcha/admin
# Choose reCAPTCHA v3 when creating a new site
# 
# Setup Instructions:
# 1. Go to https://www.google.com/recaptcha/admin
# 2. Click the + button to create a new site
# 3. Select "reCAPTCHA v3" as the type
# 4. Add your domains (e.g., colourclouds.digital, localhost)
# 5. Copy the Site Key and Secret Key below
#
# For detailed setup instructions, see RECAPTCHA_SETUP.md

# Public site key (used in the frontend)
# This key is safe to expose in client-side code
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your-recaptcha-site-key-here

# Secret key (used in the backend for verification)
# KEEP THIS SECRET! Never expose this in client-side code
RECAPTCHA_SECRET_KEY=your-recaptcha-secret-key-here